<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">


    <changeSet id="create-installer-table" author="Dizaled">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="installer"/>
            </not>
        </preConditions>
        <createTable tableName="installer">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_installer"/>
            </column>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="phone" type="VARCHAR(50)">
                <constraints nullable="false"
                             unique="true"
                             uniqueConstraintName="uk_installer_phone"/>
            </column>
            <column name="tg_id" type="VARCHAR(100)"/>
            <column name="max_id" type="VARCHAR(100)"/>
            <column name="user_id" type="UUID">
                <constraints nullable="true"
                             unique="true"
                             uniqueConstraintName="uk_installer_user"
                             foreignKeyName="fk_installer_user"
                             referencedTableName="users"
                             referencedColumnNames="id"
                             deleteCascade="true"/>
            </column>
        </createTable>

        <sql dbms="postgresql">
            ALTER TABLE installer ALTER COLUMN id SET DEFAULT gen_random_uuid();
        </sql>
        <sql dbms="h2">
            ALTER TABLE installer ALTER COLUMN id SET DEFAULT RANDOM_UUID();
        </sql>
    </changeSet>

</databaseChangeLog>