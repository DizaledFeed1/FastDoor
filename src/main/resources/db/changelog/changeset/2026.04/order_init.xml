<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="create-orders-table" author="Dizaled">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="orders"/>
            </not>
        </preConditions>
        <createTable tableName="orders">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_orders" />
            </column>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="address" type="VARCHAR(500)"/>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="message_seller" type="VARCHAR(1000)"/>
            <column name="message_main_installer" type="VARCHAR(1000)"/>
            <column name="door_limits_id" type="UUID">
                <constraints nullable="true"
                             foreignKeyName="fk_orders_door_limits"
                             referencedTableName="door_limits"
                             referencedColumnNames="id"/>
            </column>
            <column name="date_order" type="DATE"/>
            <column name="place_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="FRONTDOORQUANTITY" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="INDOORQUANTITY" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="installer_id" type="UUID">
                <constraints nullable="true"
                             foreignKeyName="fk_orders_installer"
                             referencedTableName="installer"
                             referencedColumnNames="id"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="true"
                             foreignKeyName="fk_orders_user"
                             referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>
            <column name="condition" type="VARCHAR(255)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql dbms="postgresql">
            ALTER TABLE orders ALTER COLUMN id SET DEFAULT gen_random_uuid();
        </sql>
        <sql dbms="h2">
            ALTER TABLE orders ALTER COLUMN id SET DEFAULT RANDOM_UUID();
        </sql>

    </changeSet>

</databaseChangeLog>