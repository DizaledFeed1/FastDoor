<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="add_hash_user_column_users_table" author="Dizaled">
        <preConditions>
            <not>
                <columnExists tableName="users" columnName="hash_user"/>
            </not>
        </preConditions>
        <addColumn tableName="users">
            <column name="hash_user" type="varchar(64)" remarks="Хэш юзера, используется как код приглашение">
                <constraints nullable="true"
                             unique="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>